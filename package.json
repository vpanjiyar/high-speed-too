{
  "name": "high-speed-too",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test tests/smoke.spec.ts --workers=50%",
    "test:e2e:quick": "playwright test tests/smoke.spec.ts --workers=50%",
    "test:e2e:full": "playwright test tests/animations.spec.ts tests/census.spec.ts tests/export.spec.ts tests/network.spec.ts tests/save-import.spec.ts tests/simulation.spec.ts tests/view-toggle.spec.ts",
    "test:e2e:sharded": "sh -c 'playwright test --shard=1/3 & playwright test --shard=2/3 & playwright test --shard=3/3 & wait'",
    "test:e2e:timebox": "playwright test --global-timeout=120000 --max-failures=1",
    "download-tiles": "node scripts/download-tiles.mjs",
    "uk-mask": "node scripts/generate-uk-mask.mjs",
    "naptan": "python tools/naptan_processor.py",
    "rail-lines": "python tools/rail_lines_processor.py",
    "diagnostic": "node scripts/diagnostic.mjs",
    "census": "python tools/census_processor.py",
    "geography": "python tools/geography_processor.py --merge-census",
    "census-merge": "npm run census && npm run geography"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "maplibre-gl": "^5.22.0",
    "pmtiles": "^4.4.0"
  }
}
